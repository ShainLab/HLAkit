# capture command errors
run_command() {
    local cmd="$*"
    log_info "Running: $cmd"
    
    # Only log stderr, not stdout
    if eval "$cmd" 2>> "$log_file"; then
        log_info "Finished: $cmd"
    else
        log_error "Command failed: $cmd"
        return 1
    fi
}

